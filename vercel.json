{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "functions": {
    "app/api/polish/route.ts": {
      "maxDuration": 60
    },
    "app/api/download/[jobId]/route.ts": {
      "maxDuration": 30
    }
  }
}
