// Prisma schema：用户 + 使用次数 + 订单 + 兑换码 + 任务记录
// 部署到 Vercel 必须用远程 Postgres（Neon 推荐），SQLite 在 Serverless 上文件系统是只读的
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  uses      Int      @default(0)  // 剩余使用次数（注册默认0次，需购买或兑换）
  createdAt DateTime @default(now())

  orders    Order[]
  jobs      Job[]
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  outTradeNo String   @unique
  amount     Int      // 支付金额（分），9.9元 = 990
  usesAdded  Int      @default(1) // 充值次数（默认1次）
  status     String   @default("pending") // pending / paid / failed
  payType    String   // wechat / alipay
  createdAt  DateTime @default(now())
  paidAt     DateTime?

  user       User     @relation(fields: [userId], references: [id])
}

// 一次性兑换码：管理员后台批量生成，咸鱼下单后发给用户
model RedeemCode {
  id         String   @id @default(cuid())
  code       String   @unique  // 12位大写字母数字
  status     String   @default("active") // active / used / disabled
  source     String   @default("xianyu") // xianyu / manual / promo
  note       String?  // 备注，例如咸鱼订单号
  usedBy     String?  // 使用者userId
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

model Job {
  id           String   @id @default(cuid())
  userId       String
  inputText    String   @db.Text  // 论文原文，可能上万字
  outputText   String?  @db.Text  // 改写后正文
  reportJson   String?  @db.Text  // 降AI味分析报告（JSON字符串）
  charsInput   Int      @default(0)
  charsOutput  Int      @default(0)
  status       String   @default("processing")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}
