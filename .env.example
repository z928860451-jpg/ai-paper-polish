# ===== 数据库（Neon 免费 Postgres，去 https://neon.tech 注册）=====
# Neon 控制台 -> Connection Details，会给你两条字符串：
#   - Pooled（带 -pooler）→ 填 DATABASE_URL，应用运行时用
#   - Direct（不带 -pooler）→ 填 DATABASE_URL_UNPOOLED，prisma migrate 用
DATABASE_URL=postgresql://用户名:密码@xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://用户名:密码@xxxx.region.aws.neon.tech/dbname?sslmode=require

# ===== DeepSeek API =====
# 实测可用模型（GET /v1/models）：deepseek-v4-flash（默认）/ deepseek-v4-pro（高质量）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_PRO=deepseek-v4-pro
LLM_API_KEY=sk-填你的key

# ===== 安全密钥（务必改成随机长串）=====
JWT_SECRET=please-change-me-to-a-long-random-string
ADMIN_SECRET=please-change-me

# ===== 单次价格（分）=====
PRICE_PER_USE_FEN=990

# ===== 虎皮椒支付（可选；不备案就不用配，走半自动收款）=====
# XUNHU_APPID=
# XUNHU_APPSECRET=
# XUNHU_NOTIFY_URL=https://your-vercel-domain.vercel.app/api/payment/notify
# XUNHU_RETURN_URL=https://your-vercel-domain.vercel.app/dashboard
# XUNHU_WAP_URL=your-vercel-domain.vercel.app
# XUNHU_WAP_NAME=笔润BiRun
